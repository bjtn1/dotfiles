{
    "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
    "name": "pywal",
    "author": "pywal",
    "themes": [
        {
            "name": "pywal",
            "appearance": "dark",
            "style": {
                "background": "#00000090",
                "editor.background": "#00000090",
                "editor.foreground": "#c7c2c3",
                "text": "#c7c2c3",
                "text.muted": "#c7c2c370",
                "text.ignored": "#c7c2c340",
                "text.placeholder": "#c7c2c350",
                "ignored": "#c7c2c330",
                "element.hover": "#c7c2c330",
                "ghost_element.hover": "#E2705130",
                "ghost_element.selected": "#E2705130",
                "ghost_element.active": "#E2705160",
                "border": "#000000",
                "editor.highlighted_line.background": "#E2705110",
                "editor.active_line.background": "#E2705110",
                "panel.background": "#00000090",
                "title_bar.background": "#00000090",
                "title_bar.inactive_background": "#00000090",
                "status_bar.background": "#00000090",
                "drop_target.background": "#00000090",
                "elevated_surface.background": "#000000",
                "toolbar.background": "#00000090",
                "tab_bar.background": "#00000090",
                "tab.inactive_background": "#00000090",
                "tab.active_background": "#E2705130",
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "#000000",
                "scrollbar.thumb.background": "#E27051",
                "editor.gutter.background": "#00000090",
                "terminal.background": "#00000010",
                "terminal.foreground": "#c7c2c3",
                "terminal.dim_foreground": "#c7c2c3",
                "terminal.bright_foreground": "#c7c2c3",
                "terminal.ansi.black": "#000000",
                "terminal.ansi.red": "#E27051",
                "terminal.ansi.green": "#F09863",
                "terminal.ansi.yellow": "#F6CA40",
                "terminal.ansi.blue": "#AC6F87",
                "terminal.ansi.magenta": "#B29C9F",
                "terminal.ansi.cyan": "#EDAB92",
                "terminal.ansi.white": "#c7c2c3",
                "terminal.ansi.bright_black": "#725d5f",
                "terminal.ansi.bright_red": "#E27051",
                "terminal.ansi.bright_green": "#F09863",
                "terminal.ansi.bright_yellow": "#F6CA40",
                "terminal.ansi.bright_blue": "#AC6F87",
                "terminal.ansi.bright_magenta": "#B29C9F",
                "terminal.ansi.bright_cyan": "#EDAB92",
                "terminal.ansi.bright_white": "#c7c2c3",
                "modified": "#E27051",
                "syntax": {
                    "attribute": {
                        "color": "#E27051"
                    },
                    "boolean": {
                      "color": "#F09863"
                    },
                    "comment": {
                      "color": "#725d5f"
                    },
                    "comment.doc": {
                      "color": "#725d5f"
                    },
                    "constant": {
                      "color": "#F09863"
                    },
                    "function": {
                      "color": "#EDAB92"
                    },
                    "keyword": {
                      "color": "#AC6F87"
                    },
                    "number": {
                      "color": "#B29C9F"
                    },
                    "operator": {
                      "color": "#AC6F87"
                    },
                    "string": {
                      "color": "#E27051"
                    },
                    "variable": {
                      "color": "#F09863"
                    }
                },
                "players": [
                  {
                    "cursor": "#E27051",
                    "background": "#000000",
                    "selection": "#E2705130"
                  }
                ]
            }
        }
    ]
}
