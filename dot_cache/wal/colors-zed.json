{
    "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
    "name": "pywal",
    "author": "pywal",
    "themes": [
        {
            "name": "pywal",
            "appearance": "dark",
            "style": {
                "background": "#00000090",
                "editor.background": "#00000090",
                "editor.foreground": "#c4c4ca",
                "text": "#c4c4ca",
                "text.muted": "#c4c4ca70",
                "text.ignored": "#c4c4ca40",
                "text.placeholder": "#c4c4ca50",
                "ignored": "#c4c4ca30",
                "element.hover": "#c4c4ca30",
                "ghost_element.hover": "#863D6F30",
                "ghost_element.selected": "#863D6F30",
                "ghost_element.active": "#863D6F60",
                "border": "#000000",
                "editor.highlighted_line.background": "#863D6F10",
                "editor.active_line.background": "#863D6F10",
                "panel.background": "#00000090",
                "title_bar.background": "#00000090",
                "title_bar.inactive_background": "#00000090",
                "status_bar.background": "#00000090",
                "drop_target.background": "#00000090",
                "elevated_surface.background": "#000000",
                "toolbar.background": "#00000090",
                "tab_bar.background": "#00000090",
                "tab.inactive_background": "#00000090",
                "tab.active_background": "#863D6F30",
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "#000000",
                "scrollbar.thumb.background": "#863D6F",
                "editor.gutter.background": "#00000090",
                "terminal.background": "#00000010",
                "terminal.foreground": "#c4c4ca",
                "terminal.dim_foreground": "#c4c4ca",
                "terminal.bright_foreground": "#c4c4ca",
                "terminal.ansi.black": "#000000",
                "terminal.ansi.red": "#863D6F",
                "terminal.ansi.green": "#9B4878",
                "terminal.ansi.yellow": "#AF5887",
                "terminal.ansi.blue": "#A17E82",
                "terminal.ansi.magenta": "#D26491",
                "terminal.ansi.cyan": "#F29DB0",
                "terminal.ansi.white": "#c4c4ca",
                "terminal.ansi.bright_black": "#646379",
                "terminal.ansi.bright_red": "#863D6F",
                "terminal.ansi.bright_green": "#9B4878",
                "terminal.ansi.bright_yellow": "#AF5887",
                "terminal.ansi.bright_blue": "#A17E82",
                "terminal.ansi.bright_magenta": "#D26491",
                "terminal.ansi.bright_cyan": "#F29DB0",
                "terminal.ansi.bright_white": "#c4c4ca",
                "modified": "#863D6F",
                "syntax": {
                    "attribute": {
                        "color": "#863D6F"
                    },
                    "boolean": {
                      "color": "#9B4878"
                    },
                    "comment": {
                      "color": "#646379"
                    },
                    "comment.doc": {
                      "color": "#646379"
                    },
                    "constant": {
                      "color": "#9B4878"
                    },
                    "function": {
                      "color": "#F29DB0"
                    },
                    "keyword": {
                      "color": "#A17E82"
                    },
                    "number": {
                      "color": "#D26491"
                    },
                    "operator": {
                      "color": "#A17E82"
                    },
                    "string": {
                      "color": "#863D6F"
                    },
                    "variable": {
                      "color": "#9B4878"
                    }
                },
                "players": [
                  {
                    "cursor": "#863D6F",
                    "background": "#000000",
                    "selection": "#863D6F30"
                  }
                ]
            }
        }
    ]
}
